# Used by `docker compose` for variable interpolation in compose.yml.
# Copy to .env at the repository root before running any Compose profile.
#
# App-level secrets/config live in apps/api/.env and apps/web/.env.local
# (copy from apps/api/.env.example and apps/web/.env.example) and are loaded
# via env_file for the `full` profile.

POSTGRES_USER=dho
POSTGRES_PASSWORD=dho_dev_password
POSTGRES_DB=dho_dev
POSTGRES_PORT=5432

POSTGRES_TEST_DB=dho_test
POSTGRES_TEST_PORT=5433

API_PORT=4000
WEB_PORT=3000

NEXT_PUBLIC_API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_WS_ORIGIN=ws://localhost:4000
