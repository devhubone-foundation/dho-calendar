# Copy to apps/api/.env for local (non-Docker) development.
NODE_ENV=development
PORT=4000

# Database (matches the `db` Compose profile's default port/credentials)
DATABASE_URL=postgresql://dho:dho_dev_password@localhost:5432/dho_dev

# JWT secrets: generate distinct random values, e.g. `openssl rand -hex 32`.
# Never reuse the values below outside local development.
JWT_ACCESS_SECRET=replace-with-a-random-32-byte-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-random-32-byte-hex-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS / cookie origin
APP_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# Reserved for the upload feature (Issue #2); validated now so later issues
# don't need to touch env plumbing.
UPLOAD_ROOT=./data/uploads

OFFICE_TIMEZONE=Europe/Sofia

# Login rate limiting / temporary lockout
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=15
