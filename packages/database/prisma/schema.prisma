generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  ADMIN
}

// Application account identity and auth state. Member-facing profile data
// (name, picture, qualification) lives on MemberProfile (added by Issue #2).
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  role                UserRole  @default(MEMBER)
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  profile              MemberProfile?
  weeklySchedules      MemberWeeklySchedule[]
  attendanceExceptions AttendanceException[]

  @@map("users")
}

// Member-facing profile fields, separate from account/auth state on User.
// Contact/login email is intentionally NOT duplicated here: PRODUCT_BLUEPRINT.md
// §10.1/§10.3 describe a single "login/contact email" field, i.e. User.email.
model MemberProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  fullName         String
  qualificationBg  String
  qualificationEn  String
  profileImagePath String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("member_profiles")
}

// One row per issued refresh token. Rotation replaces a row (revokedAt set,
// replacedById recorded) rather than mutating it in place.
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Minimal foundation only: actor/action/target/metadata storage. Retention
// scanning, cleanup scheduling, and the admin audit UI belong to Issue #5.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("audit_logs")
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  ATTENDING
  NOT_SURE
  NOT_ATTENDING
}

// Versioned per weekday: an admin edit inserts a new row with a fresh
// effectiveFrom instead of mutating history, so resolving a past date always
// finds the version that was actually in force on that date (ARCHITECTURE.md
// §11 "Schedule changes apply only to future dates"). Resolution = latest row
// for a weekday with effectiveFrom <= the requested date. Seed rows use a
// fixed epoch effectiveFrom so every real-world date resolves to something.
model OfficeScheduleDefault {
  id            String   @id @default(cuid())
  weekday       Weekday
  isOpen        Boolean
  startTime     String?
  endTime       String?
  effectiveFrom DateTime @db.Date
  createdAt     DateTime @default(now())

  @@index([weekday, effectiveFrom])
  @@map("office_schedule_defaults")
}

// One row per calendar date; always wins over the weekly default for that
// exact date (open/close/change-hours), per PRODUCT_BLUEPRINT.md §9.3.
model OfficeScheduleException {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  isOpen    Boolean
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("office_schedule_exceptions")
}

// A member's personal recurring weekly schedule, versioned the same way as
// OfficeScheduleDefault. Until a member has any rows for a given weekday, the
// resolver falls back to the office default as of the member's account
// creation date (see AttendanceService) rather than materializing a copy.
model MemberWeeklySchedule {
  id            String   @id @default(cuid())
  userId        String
  weekday       Weekday
  attends       Boolean
  startTime     String?
  endTime       String?
  effectiveFrom DateTime @db.Date
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekday, effectiveFrom])
  @@map("member_weekly_schedules")
}

// A member's date-specific override; always wins over their weekly schedule
// for that exact date (PRODUCT_BLUEPRINT.md §12.6).
model AttendanceException {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  status    AttendanceStatus
  startTime String?
  endTime   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance_exceptions")
}

enum EventRecurrenceFrequency {
  NONE
  WEEKLY
}

enum EventRecurrenceEndType {
  COUNT
  UNTIL
}

// A public event definition (PRODUCT_BLUEPRINT.md §14). A non-recurring event
// has frequency=NONE and expands to exactly one occurrence at startAt/endAt.
// A recurring event repeats weekly on `byWeekdays`, ending by either a fixed
// occurrence COUNT or an UNTIL date. `endsBeforeDate` is a hard cap set only
// by a "this and future" edit/delete split (see EventRecurrenceException doc
// comment) — it is not part of the user-facing recurrence definition and
// exists purely to stop this series' occurrences before the split point while
// leaving the original COUNT/UNTIL untouched for historical clarity.
// `splitFromSeriesId` records lineage for a series created by such a split;
// it is a plain reference (no FK) used only for audit/debugging.
model EventSeries {
  id                String                    @id @default(cuid())
  titleBg           String
  titleEn           String
  descriptionBg     String
  descriptionEn     String
  startAt           DateTime
  endAt             DateTime
  isAllDay          Boolean
  location          String
  coverImagePath    String?
  frequency         EventRecurrenceFrequency  @default(NONE)
  byWeekdays        Weekday[]
  recurrenceEndType EventRecurrenceEndType?
  recurrenceCount   Int?
  recurrenceUntil   DateTime?                 @db.Date
  endsBeforeDate    DateTime?                 @db.Date
  splitFromSeriesId String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  exceptions EventRecurrenceException[]

  @@index([startAt])
  @@map("event_series")
}

// An override for one originally-scheduled occurrence of a recurring series
// (PRODUCT_BLUEPRINT.md §14.8, "this occurrence" scope). `occurrenceDate` is
// the occurrence's original scheduled calendar date (before any override) and
// is the stable key clients use to address it. `isCancelled` represents a
// "this occurrence" delete; otherwise every content field is populated
// together (a full snapshot of the edited occurrence, not a partial patch) —
// the cover image is intentionally excluded and always inherited from the
// parent series.
model EventRecurrenceException {
  id             String    @id @default(cuid())
  seriesId       String
  occurrenceDate DateTime  @db.Date
  isCancelled    Boolean   @default(false)
  titleBg        String?
  titleEn        String?
  descriptionBg  String?
  descriptionEn  String?
  startAt        DateTime?
  endAt          DateTime?
  isAllDay       Boolean?
  location       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  series EventSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, occurrenceDate])
  @@map("event_recurrence_exceptions")
}
